# ===== Backend API =====
API_HOST=0.0.0.0
API_PORT=5000
FLASK_DEBUG=false
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
MAX_TEXT_LENGTH=512

# Optional: enable optional toxicity model integration in future extension
TOXICITY_MODEL=

# ===== Discord Bot =====
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_GUILD_ID=your_test_server_id
EMOTION_API_URL=http://127.0.0.1:5000
MOD_LOG_CHANNEL_ID=

# Rate limiting and behavior tuning
REPLY_COOLDOWN_MS=45000
REPEATED_ANGER_WINDOW_MS=600000
REPEATED_ANGER_COUNT=3
THRESHOLD_ANGER=0.8
THRESHOLD_SADNESS=0.7
THRESHOLD_DISGUST=0.75
THRESHOLD_FEAR=0.75
